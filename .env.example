# ── GitHub App (OAuth web flow) credentials ──────────────────
# Create at: https://github.com/settings/apps → New GitHub App
# 1) Enable "Request user authorization (OAuth) during installation"
# 2) Keep "User-to-server token expiration" enabled (recommended)
# 3) Set callback URL to: <your app origin>/auth/callback
#
# Local callback example: http://localhost:5173/auth/callback
# Production callback:     https://your-domain.com/auth/callback
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Used to sign/verify auth cookies (use a long random string; do not reuse API keys)
AUTH_SESSION_SECRET=

# Optional: force a fixed callback URL for token exchange checks.
# If omitted, backend infers <origin>/auth/callback from request headers.
GITHUB_AUTH_CALLBACK_URL=

# Backward-compatible aliases (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OpenAI ───────────────────────────────────────────────────
# Required for Ask Repo (embeddings always use OpenAI)
OPENAI_API_KEY=

# ── LLM Provider ─────────────────────────────────────────────
# Options: openai | deepseek | groq | gemini | claude
LLM_PROVIDER=openai

# ── DeepSeek (only when LLM_PROVIDER=deepseek) ───────────────
DEEPSEEK_API_KEY=

# ── Groq (only when LLM_PROVIDER=groq) ───────────────────────
# Sign up at https://console.groq.com → API Keys
GROQ_API_KEY=

# ── Google Gemini (only when LLM_PROVIDER=gemini) ────────────
# Sign up at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Anthropic Claude (only when LLM_PROVIDER=claude) ─────────
# Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Upstash Vector ───────────────────────────────────────────
# Sign up at https://upstash.com → Create a Vector index (1536 dims, cosine)
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# ── Upstash Redis ────────────────────────────────────────────
# Sign up at https://upstash.com → Create a Redis database
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Rate limiting ────────────────────────────────────────────
# Max questions per user per day (default: 20)
RAG_DAILY_LIMIT=20
# Max index/re-index operations per user per day (default: 5)
RAG_DAILY_INGEST_LIMIT=5

# ── Admin users (unlimited rate limit, comma-separated) ──────
ADMIN_GITHUB_USERS=
